{
  "name": "urlaubsverwaltung",
  "description": "Paperless absence management",
  "private": true,
  "scripts": {
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/main/javascript",
    "lint:report": "eslint src/main/javascript -f json -o target/js-eslint/report.json",
    "build": "concurrently 'npm:js' 'npm:css'",
    "build:dev": "concurrently 'npm:js:dev' 'npm:css:dev'",
    "build:watch": "concurrently 'npm:js:watch' 'npm:css:watch'",
    "js": "cross-env NODE_ENV=production rollup -c",
    "js:dev": "cross-env NODE_ENV=development rollup -c",
    "js:watch": "cross-env NODE_ENV=development rollup -c --watch",
    "css": "cross-env NODE_ENV=production postcss src/main/css/bundles --dir target/classes/static/css",
    "css:dev": "cross-env NODE_ENV=development concurrently 'npm:css:build:*'",
    "css:watch": "onchange -i src/main/css -- npm run css:dev",
    "format": "concurrently 'npm:format:*'",
    "format:html": "prettier --write src/main/resources/templates",
    "format:js": "prettier --write src/main/javascript",
    "format:css": "prettier --write src/main/css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/urlaubsverwaltung/urlaubsverwaltung.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/urlaubsverwaltung/urlaubsverwaltung/issues"
  },
  "homepage": "https://github.com/urlaubsverwaltung/urlaubsverwaltung#readme",
  "dependencies": {
    "@duetds/date-picker": "1.4.0",
    "@hotwired/turbo": "8.0.23",
    "@popperjs/core": "2.11.8",
    "@ungap/custom-elements": "1.3.0",
    "apexcharts": "5.10.6",
    "idiomorph": "0.7.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-dynamic-import-vars": "2.1.5",
    "@rollup/plugin-inject": "5.0.5",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@tailwindcss/postcss": "4.2.2",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "10.5.0",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "cssnano": "7.1.5",
    "date-fns": "3.6.0",
    "esbuild": "0.28.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unicorn": "62.0.0",
    "fast-glob": "3.3.3",
    "fetch-mock": "12.6.0",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "node-fetch": "2.7.0",
    "onchange": "7.1.0",
    "postcss": "8.5.10",
    "postcss-cli": "11.0.1",
    "postcss-import": "16.1.1",
    "postcss-load-config": "6.0.1",
    "postcss-url": "10.1.3",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "rollup": "4.60.2",
    "rollup-plugin-esbuild": "6.2.1",
    "tailwindcss": "4.2.2",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{js,html,svg,css}": [
      "prettier --write"
    ]
  }
}
